# ---- Borderless Pay environment template ----
# Copy to .env and fill in REAL values before any production deploy.
# NEVER commit the real .env. In production the server refuses to start unless
# BP_SIGNING_SECRET and BP_ENC_KEY are set (fail-closed).

# Environment: development | production
BP_ENV=production
NODE_ENV=production

# Port to listen on
PORT=4000

# Path to the file-backed store (use a mounted volume in production)
BP_DB=/app/data/db.json

# REQUIRED IN PRODUCTION ------------------------------------------------------
# HMAC secret used to sign payment authorizations.
# Generate: openssl rand -hex 48
BP_SIGNING_SECRET=

# AES-256-GCM key for field-level encryption at rest.
# Provide EITHER 64 hex chars (32 bytes) OR a long passphrase (derived via scrypt).
# Generate: openssl rand -hex 32
BP_ENC_KEY=

# CORS allowlist (comma-separated origins). Empty in production = same-origin only.
# Example: https://app.borderlesspay.com,https://borderlesspay.com
BP_CORS_ORIGINS=

# Set true ONLY when running behind a trusted reverse proxy / load balancer,
# so the client IP is read from X-Forwarded-For for rate limiting.
BP_TRUST_PROXY=true

# OPTIONAL TUNING (sane defaults shown) ---------------------------------------
# Request body size cap (bytes)
BP_BODY_LIMIT=1048576
# Session lifetime (ms) — default 24h
BP_SESSION_TTL_MS=86400000
# Rate limits (per IP, sliding window)
BP_RL_WINDOW_MS=60000
BP_RL_MAX=120
BP_RL_AUTH_MAX=20
BP_RL_PAYMENT_MAX=30
# Failed-PIN lockout
BP_LOCK_MAX_FAILS=5
BP_LOCK_WINDOW_MS=900000
BP_LOCK_MS=900000
# Transaction limits (minor units, i.e. paise)
BP_TXN_MIN_MINOR=100
BP_TXN_MAX_MINOR=20000000
BP_INTL_TXN_MAX_MINOR=50000000
BP_DAILY_TOTAL_MAX_MINOR=100000000
BP_DAILY_COUNT_MAX=100
